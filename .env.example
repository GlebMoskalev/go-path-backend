# Service
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_SHUTDOWN_TIMEOUT=10s

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mydatabase
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/google/callback
GOOGLE_USER_INFO_URL=https://www.googleapis.com/oauth2/v2/userinfo

# Environment: prod/dev
ENV=dev

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# AI
AI_API_KEY=your-api-key
AI_API_URL=https://api.openai.com/v1
AI_MODEL_PASSED_TESTS=gpt-4
AI_MAX_TOKENS_TASK=1000
AI_MAX_TOKENS_PROJECT=1500
AI_TEMPERATURE=0.7
AI_TOP_P=1.0
AI_SYSTEM_PROMPT_TASK=You are a code reviewer analyzing passed solutions.
AI_USER_PROMPT_TASK=Review this code: {{code}}
AI_SYSTEM_PROMPT_PROJECT=You are a code reviewer analyzing project solutions.
AI_USER_PROMPT_PROJECT=Review this project code: {{code}}
AI_SYSTEM_PROMPT_ERROR=You are a helpful assistant analyzing code errors and test failures.
AI_USER_PROMPT_ERROR=Analyze the following error:\n\nTask: {{title}}\nDescription: {{description}}\n\nUser Code:\n{{code}}\n\nError Output:\n{{error}}\n\nProvide a clear explanation of what went wrong and how to fix it.